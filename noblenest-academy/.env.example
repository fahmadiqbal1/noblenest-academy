APP_NAME="Noble Nest Academy"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=10

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=noblenest
DB_USERNAME=noblenest
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
# Phase 5: Resend is the production transactional mailer. Get a key at
# https://resend.com and set RESEND_API_KEY below.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Legacy SMTP/Mailgun config kept below in case you fall back to MAIL_MAILER=smtp:
MAIL_SCHEME=null
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# AI Curriculum Sidecar
CURRICULUM_AI_URL=http://127.0.0.1:8001
ANTHROPIC_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# PAYMENT GATEWAYS
# =============================================================================

# Stripe Configuration
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# PayPal Configuration
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox
PAYPAL_MODE=sandbox

# =============================================================================
# AI PROVIDERS (Configure at least one for AI Assistant functionality)
# See admin/orchestrator for provider management
# =============================================================================

# Default AI Provider (configured via admin panel)
AI_ASSIST_PROVIDER=mock

# =============================================================================
# LIVE CLASS (Daily.co)
# =============================================================================
DAILY_CO_API_KEY=
DAILY_CO_DOMAIN=

# =============================================================================
# VIDEO GENERATION (HeyGen + TTS)
# =============================================================================
HEYGEN_API_KEY=
HEYGEN_DEFAULT_AVATAR_ID=
HEYGEN_DEFAULT_VOICE_ID=

# TTS Provider: openai | elevenlabs
TTS_PROVIDER=openai

# OpenAI (used for TTS + GPT-4o-mini translation when TTS_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=shimmer

# ElevenLabs (used when TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# =============================================================================
# PWA PUSH NOTIFICATIONS (VAPID)
# Run: php artisan web-push:generate-keys
# =============================================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# =============================================================================
# GEMINI (Image Generation)
# =============================================================================
GEMINI_API_KEY=

# =============================================================================
# AI GENERATION DAILY LIMITS
# =============================================================================
AI_DAILY_IMAGE_LIMIT=200
AI_DAILY_AUDIO_LIMIT=50
AI_DAILY_VIDEO_LIMIT=10

# Phase 3 i18n translator (Groq llama-3.3-70b-versatile)
GROQ_API_KEY=

# Phase 9 — bearer token gating /health/detailed (32-byte random in prod)
HEALTH_TOKEN=
