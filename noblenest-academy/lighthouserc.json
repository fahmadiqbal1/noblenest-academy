{
    "ci": {
        "collect": {
            "url": [
                "http://localhost:8000/",
                "http://localhost:8000/pricing",
                "http://localhost:8000/login"
            ],
            "settings": {
                "formFactor": "mobile",
                "screenEmulation": {
                    "mobile": true,
                    "width": 375,
                    "height": 812,
                    "deviceScaleFactor": 3
                }
            },
            "numberOfRuns": 1
        },
        "assert": {
            "assertions": {
                "categories:performance": ["error", { "minScore": 0.85 }],
                "categories:accessibility": ["error", { "minScore": 0.95 }],
                "categories:best-practices": ["error", { "minScore": 0.95 }],
                "categories:seo": ["error", { "minScore": 0.95 }]
            }
        },
        "upload": {
            "target": "temporary-public-storage"
        }
    },
    "_todo_phase_8_1": "Bump performance to 0.90 after image optimization (WebP/AVIF + responsive srcset) lands."
}
