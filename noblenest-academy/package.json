{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "fonts": "bash scripts/fetch-fonts.sh",
        "a11y": "axe http://localhost:8000/ http://localhost:8000/login http://localhost:8000/pricing http://localhost:8000/register http://localhost:8000/forgot-password --tags wcag2a,wcag2aa,wcag21a,wcag21aa --exit",
        "a11y:legacy": "pa11y-ci",
        "lighthouse": "lhci autorun",
        "launch:checks": "npm run fonts && npm run build && npm run a11y && npm run lighthouse"
    },
    "devDependencies": {
        "@axe-core/cli": "^4.10.0",
        "@lhci/cli": "^0.14.0",
        "@tailwindcss/forms": "^0.5.10",
        "@tailwindcss/typography": "^0.5.16",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "crg-dev-kit": "^2.2.6",
        "laravel-vite-plugin": "^2.0.0",
        "lucide": "^0.511.0",
        "pa11y-ci": "^3.1.0",
        "tailwindcss": "^4.0.0",
        "tailwindcss-rtl": "^0.9.0",
        "vite": "^7.0.4",
        "vite-plugin-image-optimizer": "^1.1.8"
    }
}
